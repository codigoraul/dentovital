---
import { resolveAsset } from '../lib/assets';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Dentista en Antofagasta | Implantes Dentales | Clínica Dentovital",
  description = "Clínica dental en Antofagasta especializada en implantes dentales, rehabilitación oral, odontología digital y estética facial. Agenda tu hora hoy.",
  canonical = "https://dentistaantofagasta.cl",
  ogImage = "https://dentistaantofagasta.cl/og-image.jpg"
} = Astro.props;

const faviconUrl = resolveAsset(Astro, 'logo-dentovital.png');
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="dentista en Antofagasta, implantes dentales Antofagasta, clínica dental Antofagasta, botox Antofagasta, estética facial Antofagasta, ortodoncia Antofagasta, endodoncia Antofagasta, rehabilitación oral Antofagasta">
  <link rel="canonical" href={canonical}>
  <link rel="icon" type="image/png" href={faviconUrl}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content="es_CL">
  <meta property="og:site_name" content="Clínica Dentovital">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Indexación -->
  <meta name="robots" content="index, follow">
  <meta name="author" content="Clínica Dentovital">
  
  <!-- Critical CSS to prevent FOUC -->
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background-color: #fff;
      color: #2c2c2c;
    }
    * {
      box-sizing: border-box;
    }
    .nav a {
      font-size: 0.95rem;
      font-weight: 500;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
