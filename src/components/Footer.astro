---
import { resolveAsset } from '../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-col">
        <img src={asset('logo-dentovital.png')} alt="Clínica Dentovital" class="footer-logo" />
        <p class="footer-tagline">Odontología moderna y estética facial en Antofagasta</p>
      </div>
      
      <div class="footer-col">
        <h4>Contacto</h4>
        <ul>
          <li>Uribe #636, oficina 306</li>
          <li>Antofagasta, Chile</li>
          <li><a href="https://wa.me/56937725890">+56 9 3772 5890</a></li>
          <li><a href="mailto:clinicaodontologicadentovital@gmail.com">clinicaodontologicadentovital@gmail.com</a></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4>Horarios</h4>
        <ul>
          <li>Lunes a viernes:</li>
          <li>09:00–13:30 | 15:00–19:30</li>
          <li>Sábados:</li>
          <li>09:00–14:00 | 15:00–17:00</li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4>Síguenos</h4>
        <div class="footer-social">
          <a href="https://instagram.com/clinica.dentovital" target="_blank" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://facebook.com/dentovital.odonto" target="_blank" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
        <p class="footer-social-handles">
          @clinica.dentovital<br>
          dentovital.odonto
        </p>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Clínica Dentovital — Todos los derechos reservados</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark);
    color: #fff;
    padding: 60px 0 30px;
  }
  
  .footer-content {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 40px;
  }
  
  .footer-logo {
    height: 60px;
    width: auto;
    margin-bottom: 15px;
  }
  
  .footer-tagline {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  .footer-col h4 {
    color: var(--primary);
    font-size: 1.2rem;
    margin-bottom: 20px;
  }
  
  .footer-col ul {
    list-style: none;
  }
  
  .footer-col ul li {
    margin-bottom: 10px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }
  
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s ease;
  }
  
  .footer-col a:hover {
    color: var(--gold);
  }
  
  .footer-social {
    display: flex;
    gap: 15px;
    margin-bottom: 15px;
  }
  
  .footer-social a {
    width: 40px;
    height: 40px;
    background: rgba(184, 149, 106, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    transition: all 0.3s ease;
  }
  
  .footer-social a:hover {
    background: var(--primary);
    color: var(--white);
    transform: translateY(-3px);
  }
  
  .footer-social-handles {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    line-height: 1.6;
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 30px;
    text-align: center;
  }
  
  .footer-bottom p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
  }
  
  @media (max-width: 968px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 580px) {
    .footer-content {
      grid-template-columns: 1fr;
    }
  }
</style>
