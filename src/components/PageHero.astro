---
import { resolveAsset } from '../lib/assets';

interface Props {
  title: string;
  description: string;
  backgroundImage: string;
}

const { title, description, backgroundImage } = Astro.props;
const backgroundUrl = resolveAsset(Astro, backgroundImage);
---

<section class="page-hero">
  <div class="hero-background" style={`background-image: url('${backgroundUrl}');`}></div>
  <div class="hero-overlay"></div>
  <div class="container">
    <div class="hero-content">
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
  }
  
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.78) 0%, rgba(44, 44, 44, 0.85) 100%);
    z-index: 1;
  }
  
  .page-hero .container {
    position: relative;
    z-index: 2;
  }
  
  .hero-content {
    text-align: center;
    color: var(--white);
  }
  
  .hero-content h1 {
    font-size: 3.2rem;
    margin-bottom: 15px;
    color: var(--white);
  }
  
  .hero-content p {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 700px;
    margin: 0 auto;
  }
  
  @media (max-width: 968px) {
    .page-hero {
      height: 300px;
    }
    
    .hero-content h1 {
      font-size: 32px;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }
  }
</style>
