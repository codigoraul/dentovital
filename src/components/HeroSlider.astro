    </div>
    
    <div class="slide">
      <div class="slide-bg" style="background-image: url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?w=1920&q=80')"></div>
      <div class="overlay"></div>
      <div class="slide-content">
        <div class="container">
