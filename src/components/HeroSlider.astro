<style>
  .hero {
    position: relative;
    height: 700px;
    overflow: hidden;
    margin-top: 72px;
  }
  
  .slider {
    position: relative;
    width: 100%;
    height: 100%;
  }
  
  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1s ease-in-out;
  }
  
  .slide.active {
    opacity: 1;
  }
  
  .slide-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }
  
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(245, 240, 232, 0.75);
  }
  
  .slide-content {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    z-index: 2;
  }
  
  .slide-content h1 {
    font-size: 3.5rem;
    color: var(--dark);
    margin-bottom: 20px;
    max-width: 700px;
  }
  
  .slide-content p {
    font-size: 1.3rem;
    color: var(--dark-mid);
    margin-bottom: 30px;
    max-width: 600px;
  }
  
  .slide-buttons {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(198, 165, 92, 0.8);
    color: #fff;
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }
  
  .slider-btn:hover {
    background: var(--gold);
    transform: translateY(-50%) scale(1.1);
  }
  
  .slider-btn.prev {
    left: 30px;
  }
  
  .slider-btn.next {
    right: 30px;
  }
  
  .slider-dots {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 15px;
    z-index: 10;
  }
  
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: 2px solid var(--gold);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .dot.active {
    background: var(--gold);
    transform: scale(1.2);
  }
  
  @media (max-width: 768px) {
    .hero {
      height: 600px;
      margin-top: 62px;
    }
    
    .slide-content h1 {
      font-size: 2.5rem;
    }
    
    .slide-content p {
      font-size: 1.1rem;
    }
    
    .slider-btn {
      width: 40px;
      height: 40px;
    }
    
    .slider-btn.prev {
      left: 15px;
    }
    
    .slider-btn.next {
      right: 15px;
    }
  }
  
  @media (max-width: 480px) {
    .hero {
      height: 500px;
    }
    
    .slide-content h1 {
      font-size: 2rem;
    }
    
    .slide-content p {
      font-size: 1rem;
    }
    
    .slide-buttons {
      flex-direction: column;
    }
  }
</style>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  const totalSlides = slides.length;
  
  function showSlide(index: number) {
    slides.forEach(slide => slide.classList.remove('active'));
    dots.forEach(dot => dot.classList.remove('active'));
    
    slides[index].classList.add('active');
    dots[index].classList.add('active');
  }
  
  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    showSlide(currentSlide);
  }
  
  function prevSlide() {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    showSlide(currentSlide);
  }
  
  document.querySelector('.next')?.addEventListener('click', nextSlide);
  document.querySelector('.prev')?.addEventListener('click', prevSlide);
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentSlide = index;
      showSlide(currentSlide);
    });
  });
  
  setInterval(nextSlide, 5000);
</script>
