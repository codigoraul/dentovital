          <div class="slide-buttons">
            <a href="https://wa.me/56937725890?text=Hola,%20quiero%20agendar%20una%20hora" target="_blank" class="btn btn-primary">Agendar Hora</a>
            <a href="#servicios" class="btn btn-outline">Ver más</a>
          </div>
