<style>
  .contacto {
    background: var(--cream);
  }
  
  .section-subtitle {
    text-align: center;
    color: var(--dark-mid);
    font-size: 1.1rem;
    margin-top: -30px;
    margin-bottom: 50px;
  }
  
  .contacto-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }
  
  .contacto-info {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  
  .info-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  
  .info-icon {
    width: 50px;
    height: 50px;
    background: var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .info-icon svg {
    color: #fff;
  }
  
  .info-item h3 {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 5px;
  }
  
  .info-item p {
    color: var(--dark-mid);
    line-height: 1.6;
  }
  
  .info-item a {
    color: var(--gold);
    transition: color 0.3s ease;
  }
  
  .info-item a:hover {
    color: var(--dark);
  }
  
  .social-links {
    display: flex;
    gap: 15px;
    margin-top: 20px;
  }
  
  .social-links a {
    width: 45px;
    height: 45px;
    background: var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: all 0.3s ease;
  }
  
  .social-links a:hover {
    background: var(--dark);
    transform: translateY(-3px);
  }
  
  .contacto-map {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
  }
  
  @media (max-width: 968px) {
    .contacto-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
