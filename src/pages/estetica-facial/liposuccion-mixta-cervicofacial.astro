---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset, resolveRoute } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout title="Liposucción Mixta Cervicofacial | Clínica Dentovital" description="Liposucción mixta cervicofacial en Antofagasta. Elimina grasa de papada y cuello con liposucción y Endoláser para redefinir el contorno facial." canonical="https://dentistaantofagasta.cl/estetica-facial/liposuccion-mixta-cervicofacial">
  <Header />

  <main style="margin-top: 90px;">
    <PageHero
      title="Liposucción Mixta Cervicofacial"
      description="Redefine tu contorno facial con tecnología avanzada"
      backgroundImage="images/bg-title/bg-estetica-facial.webp"
    />

    <section class="servicio-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-image">
            <img src={asset('images/estetica-facial/liposuccion-mixta.webp')} alt="Liposucción Mixta Cervicofacial" />
          </div>

          <div class="detail-content">
            <h2 class="servicio-title">Liposucción Mixta Cervicofacial</h2>

            <p>
              La liposucción mixta cervicofacial es un procedimiento estético enfocado en papada, cuello y contorno mandibular, que combina dos técnicas para lograr mejores resultados.
            </p>

            <h3>🔹 1. Liposucción tradicional</h3>
            <p>
              Se utiliza una cánula fina para aspirar grasa localizada del cuello y papada, ayudando a definir el perfil facial.
            </p>

            <h3>🔹 2. Endoláser</h3>
            <p>Se introduce una fibra láser delgada bajo la piel que emite energía para:</p>
            <ul>
              <li>Licuar grasa residual</li>
              <li>Estimular colágeno</li>
              <li>Reafirmar la piel</li>
              <li>Mejorar flacidez y tensado del cuello</li>
            </ul>

            <h3>✨ ¿Por qué se combinan?</h3>
            <p>
              Porque la técnica tradicional elimina volumen, mientras que el endoláser mejora la retracción de la piel y la calidad del tejido. Esto permite un resultado más marcado y armónico.
            </p>

            <h3>Beneficios</h3>
            <ul>
              <li>Reducción de papada</li>
              <li>Definición del ángulo cuello-mentón</li>
              <li>Perfil más estilizado</li>
              <li>Menor flacidez post extracción de grasa</li>
              <li>Recuperación generalmente más rápida que cirugías mayores</li>
            </ul>

            <h3>Ideal para personas con:</h3>
            <ul>
              <li>Papada por grasa localizada</li>
              <li>Cuello poco definido</li>
              <li>Flacidez leve a moderada</li>
              <li>Deseo de mejora sin lifting facial completo</li>
            </ul>

            <div class="cta-box">
              <p>¿Quieres redefinir tu contorno facial?</p>
              <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
            </div>

            <div class="back-link">
              <a href={resolveRoute(Astro, '/estetica-facial')}>
                <span class="arrow">&larr;</span> Volver a Estética Facial
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .servicio-detail { padding: 80px 0; background: #fff; }
  .detail-grid { display: grid; grid-template-columns: 2fr 3fr; gap: 50px; align-items: start; }
  .detail-image { position: sticky; top: 120px; }
  .detail-image img { width: 100%; height: auto; border-radius: 12px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); }
  .detail-content { padding-top: 0; }
  .servicio-title { font-size: 2.2rem; color: var(--dark); margin-bottom: 25px; font-weight: 700; line-height: 1.2; }
  .detail-content p { font-size: 1.1rem; line-height: 1.8; color: var(--dark-mid); margin-bottom: 20px; }
  .detail-content h3 { font-size: 1.5rem; color: var(--dark); margin: 35px 0 15px; font-weight: 600; }
  .detail-content ul { margin-left: 25px; margin-bottom: 25px; }
  .detail-content li { font-size: 1.05rem; line-height: 1.8; color: var(--dark-mid); margin-bottom: 8px; }
  .detail-content strong { color: var(--dark); }
  .cta-box { background: var(--cream); padding: 35px; border-radius: 10px; text-align: center; margin-top: 40px; }
  .cta-box p { font-size: 1.2rem; color: var(--dark); margin-bottom: 20px; }
  .back-link { margin-top: 30px; }
  .back-link a { display: inline-flex; align-items: center; gap: 6px; color: var(--primary); font-size: 1.05rem; text-decoration: none; font-weight: 500; transition: color 0.3s ease; }
  .back-link a:hover { color: var(--primary-dark, var(--dark)); }
  .back-link .arrow { font-size: 1.2rem; }
  @media (max-width: 968px) {
    .detail-grid { grid-template-columns: 1fr; gap: 30px; }
    .detail-image { position: static; max-width: 500px; margin: 0 auto; }
    .servicio-title { font-size: 1.8rem; }
  }
</style>
