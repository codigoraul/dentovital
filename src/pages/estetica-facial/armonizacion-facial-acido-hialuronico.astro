---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset, resolveRoute } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout title="Armonización Facial con Ácido Hialurónico | Clínica Dentovital" description="Tratamiento de armonización facial con ácido hialurónico en Antofagasta. Resultados naturales y seguros sin cirugía.">
  <Header />

  <main style="margin-top: 90px;">
    <PageHero
      title="Armonización Facial con Ácido Hialurónico"
      description="Mejora, equilibra y realza tus rasgos de forma natural y segura"
      backgroundImage="images/bg-title/bg-estetica-facial.webp"
    />

    <section class="servicio-detail">
      <div class="container">
        <div class="detail-grid">
          <!-- Columna imagen (40%) -->
          <div class="detail-image">
            <img src={asset('images/estetica-facial/Armonizacion-facial.webp')} alt="Armonización Facial con Ácido Hialurónico" />
          </div>

          <!-- Columna contenido (60%) -->
          <div class="detail-content">
            <h2 class="servicio-title">Armonización Facial con Ácido Hialurónico</h2>

            <p>
              La armonización facial con ácido hialurónico es un tratamiento estético avanzado que permite
              <strong>mejorar, equilibrar y realzar los rasgos del rostro de forma natural y segura</strong>,
              sin necesidad de cirugía.
            </p>
            <p>
              En Clínica Dentovital trabajamos con un enfoque <strong>personalizado y basado en anatomía facial</strong>,
              evaluando proporciones, simetría y proyección para lograr resultados armónicos, elegantes y acordes a cada paciente.
            </p>

            <h3>¿Qué se puede mejorar con ácido hialurónico?</h3>
            <ul>
              <li>Aumento y definición de labios</li>
              <li>Rinomodelación</li>
              <li>Relleno de surcos nasogenianos (líneas de la sonrisa)</li>
              <li>Proyección de pómulos</li>
              <li>Definición de mandíbula y mentón</li>
              <li>Corrección de ojeras</li>
              <li>Rejuvenecimiento facial sin cirugía</li>
            </ul>

            <h3>Resultados naturales y progresivos</h3>
            <p>
              Nuestro objetivo no es cambiar tu rostro, sino <strong>potenciar tu belleza natural</strong>.
              Utilizamos técnicas avanzadas que permiten resultados <strong>sutiles, equilibrados y altamente estéticos</strong>,
              evitando excesos o sobrecargas.
            </p>

            <h3>Seguridad y tecnología</h3>
            <p>
              El procedimiento es realizado por profesionales capacitados, utilizando
              <strong>productos de alta calidad y técnicas seguras</strong>, con mínima molestia y recuperación rápida.
              Además, aplicamos criterios clínicos precisos para asegurar resultados <strong>predecibles y duraderos</strong>.
            </p>

            <h3>¿Cuánto duran los resultados?</h3>
            <p>
              Los efectos del ácido hialurónico suelen durar entre <strong>8 a 18 meses</strong>,
              dependiendo de la zona tratada y el metabolismo de cada paciente.
            </p>

            <h3>Recupera frescura, definición y confianza</h3>
            <p>
              La armonización facial no solo mejora la apariencia, también impacta directamente en la seguridad personal.
              Hoy puedes verte mejor, manteniendo tu esencia.
            </p>

            <div class="cta-box">
              <p>¿Quieres armonizar tu rostro?</p>
              <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
            </div>

            <div class="back-link">
              <a href={resolveRoute(Astro, '/estetica-facial')}>
                <span class="arrow">&larr;</span> Volver a Estética Facial
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .servicio-detail {
    padding: 80px 0;
    background: #fff;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 50px;
    align-items: start;
  }

  .detail-image {
    position: sticky;
    top: 120px;
  }

  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .detail-content {
    padding-top: 0;
  }

  .servicio-title {
    font-size: 2.2rem;
    color: var(--dark);
    margin-bottom: 25px;
    font-weight: 700;
    line-height: 1.2;
  }

  .detail-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 20px;
  }

  .detail-content h3 {
    font-size: 1.5rem;
    color: var(--dark);
    margin: 35px 0 15px;
    font-weight: 600;
  }

  .detail-content ul {
    margin-left: 25px;
    margin-bottom: 25px;
  }

  .detail-content li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 8px;
  }

  .detail-content strong {
    color: var(--dark);
  }

  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 40px;
  }

  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }

  .back-link {
    margin-top: 30px;
  }

  .back-link a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-size: 1.05rem;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .back-link a:hover {
    color: var(--primary-dark, var(--dark));
  }

  .back-link .arrow {
    font-size: 1.2rem;
  }

  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .detail-image {
      position: static;
      max-width: 500px;
      margin: 0 auto;
    }

    .servicio-title {
      font-size: 1.8rem;
    }
  }
</style>
