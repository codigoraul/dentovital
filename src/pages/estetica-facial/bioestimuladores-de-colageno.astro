---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset, resolveRoute } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout title="Bioestimuladores de Colágeno | Clínica Dentovital" description="Tratamiento con bioestimuladores de colágeno en Antofagasta. Rejuvenece tu piel desde el interior con Sculptra, Profhilo, Cientific y Fulloria.">
  <Header />

  <main style="margin-top: 90px;">
    <PageHero
      title="Bioestimuladores de Colágeno"
      description="Rejuvenece tu piel desde el interior activando la producción natural de colágeno"
      backgroundImage="images/bg-title/bg-estetica-facial.webp"
    />

    <section class="servicio-detail">
      <div class="container">
        <div class="detail-grid">
          <!-- Columna imagen (40%) -->
          <div class="detail-image">
            <img src={asset('images/estetica-facial/Bioestimuladores-de-colageno.webp')} alt="Bioestimuladores de Colágeno" />
          </div>

          <!-- Columna contenido (60%) -->
          <div class="detail-content">
            <h2 class="servicio-title">Bioestimuladores de Colágeno</h2>

            <p>
              Los bioestimuladores de colágeno son tratamientos avanzados que permiten <strong>rejuvenecer la piel desde el interior</strong>,
              activando la producción natural de colágeno y mejorando progresivamente la firmeza, elasticidad y calidad de la piel.
            </p>
            <p>
              En Clínica Dentovital trabajamos con productos de última generación como <strong>Sculptra®, Cientific®, Profhilo® y Fulloria®</strong>,
              seleccionando el más adecuado según las necesidades de cada paciente para lograr resultados <strong>naturales, progresivos y de alta calidad estética</strong>.
            </p>

            <h3>¿Cómo funcionan?</h3>
            <p>
              A diferencia de los rellenos tradicionales, los bioestimuladores <strong>no generan volumen inmediato</strong>,
              sino que actúan estimulando los propios mecanismos de regeneración del cuerpo, logrando:
            </p>
            <ul>
              <li>Aumento de colágeno y elastina</li>
              <li>Mejora de la firmeza y elasticidad</li>
              <li>Reducción de flacidez</li>
              <li>Mejora de la textura y calidad de la piel</li>
              <li>Rejuvenecimiento global del rostro</li>
            </ul>

            <h3>Tipos de bioestimuladores que utilizamos</h3>

            <div class="producto-box">
              <h4>Sculptra® (Ácido Poliláctico - PLLA)</h4>
              <ul>
                <li><strong>Componente principal:</strong> Ácido poliláctico</li>
                <li><strong>Mecanismo:</strong> Estimula colágeno tipo I de forma profunda</li>
                <li><strong>Efecto principal:</strong> Reposición estructural + firmeza</li>
                <li><strong>Ideal para:</strong> Flacidez moderada a avanzada, pérdida de volumen por envejecimiento, rostros más "descendidos"</li>
              </ul>
              <p>Es el bioestimulador <strong>más potente y estructural</strong>. No da volumen inmediato, pero reconstruye la base del rostro con el tiempo.</p>
            </div>

            <div class="producto-box">
              <h4>Profhilo® (Ácido Hialurónico ultrapuro)</h4>
              <ul>
                <li><strong>Componente principal:</strong> Ácido hialurónico estabilizado (sin reticulación química tradicional)</li>
                <li><strong>Mecanismo:</strong> Bio-remodelación + hidratación profunda</li>
                <li><strong>Efecto principal:</strong> Calidad de piel + elasticidad</li>
                <li><strong>Ideal para:</strong> Piel deshidratada o envejecida, falta de luminosidad, pacientes que no quieren volumen</li>
              </ul>
              <p>Es el tratamiento con <strong>mayor efecto "glow"</strong>, mejora la piel sin cambiar la forma del rostro.</p>
            </div>

            <div class="producto-box">
              <h4>Cientific® (Hidroxiapatita de calcio)</h4>
              <ul>
                <li><strong>Componente principal:</strong> Hidroxiapatita de calcio (CaHA) o complejos bioactivos</li>
                <li><strong>Mecanismo:</strong> Estimulación de colágeno + soporte dérmico</li>
                <li><strong>Efecto principal:</strong> Firmeza + mejora de textura</li>
                <li><strong>Ideal para:</strong> Flacidez leve a moderada, pacientes que buscan equilibrio entre firmeza y naturalidad</li>
              </ul>
            </div>

            <div class="producto-box">
              <h4>Fulloria® (Complejos bioestimuladores + ácido hialurónico)</h4>
              <ul>
                <li><strong>Componente principal:</strong> Ácido hialurónico + agentes bioestimuladores</li>
                <li><strong>Mecanismo:</strong> Hidratación + estimulación dérmica</li>
                <li><strong>Efecto principal:</strong> Mejora global de la piel</li>
                <li><strong>Ideal para:</strong> Prevención del envejecimiento, piel joven o primeros signos de flacidez, tratamientos de mantenimiento</li>
              </ul>
            </div>

            <h3>¿En qué zonas se pueden aplicar?</h3>
            <ul>
              <li>Rostro</li>
              <li>Cuello</li>
            </ul>

            <h3>Resultados naturales y progresivos</h3>
            <p>
              Los resultados no son inmediatos, ya que dependen del proceso biológico de formación de colágeno.
              El efecto se desarrolla en semanas y meses, logrando una piel <strong>más firme, hidratada, luminosa y rejuvenecida</strong>.
            </p>

            <h3>Procedimiento mínimamente invasivo</h3>
            <p>
              Se realiza mediante microinyecciones, con molestias leves y recuperación rápida.
              Es un tratamiento ambulatorio que permite retomar actividades normales el mismo día.
            </p>

            <h3>¿Cuántas sesiones se recomiendan?</h3>
            <p>
              Dependiendo del producto y del diagnóstico, se indican entre <strong>1 a 3 sesiones</strong>,
              con protocolos personalizados para cada paciente.
            </p>

            <h3>Rejuvenece tu piel desde el origen</h3>
            <p>
              Los bioestimuladores son la mejor opción para quienes buscan un rejuvenecimiento real y duradero,
              mejorando la piel <strong>desde adentro, sin alterar volúmenes ni expresiones</strong>.
            </p>

            <div class="cta-box">
              <p>¿Quieres rejuvenecer tu piel de forma natural y progresiva?</p>
              <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
            </div>

            <div class="back-link">
              <a href={resolveRoute(Astro, '/estetica-facial')}>
                <span class="arrow">&larr;</span> Volver a Estética Facial
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .servicio-detail {
    padding: 80px 0;
    background: #fff;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 50px;
    align-items: start;
  }

  .detail-image {
    position: sticky;
    top: 120px;
  }

  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .detail-content {
    padding-top: 0;
  }

  .servicio-title {
    font-size: 2.2rem;
    color: var(--dark);
    margin-bottom: 25px;
    font-weight: 700;
    line-height: 1.2;
  }

  .detail-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 20px;
  }

  .detail-content h3 {
    font-size: 1.5rem;
    color: var(--dark);
    margin: 35px 0 15px;
    font-weight: 600;
  }

  .detail-content h4 {
    font-size: 1.25rem;
    color: var(--primary);
    margin-bottom: 12px;
    font-weight: 600;
  }

  .detail-content ul {
    margin-left: 25px;
    margin-bottom: 25px;
  }

  .detail-content li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 8px;
  }

  .detail-content strong {
    color: var(--dark);
  }

  .producto-box {
    background: var(--cream, #f9f6f1);
    border-radius: 10px;
    padding: 25px 30px;
    margin-bottom: 20px;
  }

  .producto-box p {
    margin-bottom: 0;
  }

  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 40px;
  }

  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }

  .back-link {
    margin-top: 30px;
  }

  .back-link a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-size: 1.05rem;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .back-link a:hover {
    color: var(--primary-dark, var(--dark));
  }

  .back-link .arrow {
    font-size: 1.2rem;
  }

  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .detail-image {
      position: static;
      max-width: 500px;
      margin: 0 auto;
    }

    .servicio-title {
      font-size: 1.8rem;
    }
  }
</style>
