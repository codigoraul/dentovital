---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset, resolveRoute } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout title="Exosomas + ADN de Salmón | Clínica Dentovital" description="Tratamiento con exosomas y ADN de salmón en Antofagasta. Regeneración celular avanzada para una piel más firme, luminosa y rejuvenecida." canonical="https://dentovital.cl/estetica-facial/exosomas-adn-salmon">
  <Header />

  <main style="margin-top: 90px;">
    <PageHero
      title="Exosomas + ADN de Salmón"
      description="Regeneración celular avanzada para una piel visiblemente rejuvenecida"
      backgroundImage="images/bg-title/bg-estetica-facial.webp"
    />

    <section class="servicio-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-image">
            <img src={asset('images/estetica-facial/exosomasyadn.webp')} alt="Exosomas + ADN de Salmón" />
          </div>

          <div class="detail-content">
            <h2 class="servicio-title">Exosomas + ADN de Salmón</h2>

            <p>
              Exosomas + ADN de salmón de MD Ceuticals es un tratamiento de bioestimulación y regeneración cutánea que combina dos activos potentes para rejuvenecer la piel.
            </p>

            <h3>¿Qué contiene?</h3>
            <ul>
              <li><strong>Exosomas:</strong> microvesículas celulares con señales biológicas que ayudan a estimular reparación, colágeno, elastina y renovación celular.</li>
              <li><strong>ADN de salmón (PDRN/PN):</strong> fragmentos de ADN purificado que favorecen hidratación profunda, reparación tisular, elasticidad y mejora de inflamación.</li>
            </ul>

            <h3>¿Para qué sirve?</h3>
            <p>Ideal para:</p>
            <ul>
              <li>Piel opaca o cansada</li>
              <li>Líneas finas y arrugas iniciales</li>
              <li>Poros y textura irregular</li>
              <li>Cicatrices leves / marcas de acné</li>
              <li>Piel deshidratada</li>
              <li>Recuperación post láser, peeling o microneedling</li>
            </ul>

            <h3>Beneficios esperados</h3>
            <ul>
              <li>Más luminosidad</li>
              <li>Piel más firme</li>
              <li>Mejor textura</li>
              <li>Hidratación intensa</li>
              <li>Aspecto más joven y saludable</li>
            </ul>

            <h3>¿Cuántas sesiones?</h3>
            <p>
              Usualmente <strong>3 a 5 sesiones</strong>, separadas cada 2 a 4 semanas, según objetivo y evaluación profesional.
            </p>

            <div class="cta-box">
              <p>¿Quieres regenerar tu piel con tecnología de última generación?</p>
              <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
            </div>

            <div class="back-link">
              <a href={resolveRoute(Astro, '/estetica-facial')}>
                <span class="arrow">&larr;</span> Volver a Estética Facial
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .servicio-detail { padding: 80px 0; background: #fff; }
  .detail-grid { display: grid; grid-template-columns: 2fr 3fr; gap: 50px; align-items: start; }
  .detail-image { position: sticky; top: 120px; }
  .detail-image img { width: 100%; height: auto; border-radius: 12px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); }
  .detail-content { padding-top: 0; }
  .servicio-title { font-size: 2.2rem; color: var(--dark); margin-bottom: 25px; font-weight: 700; line-height: 1.2; }
  .detail-content p { font-size: 1.1rem; line-height: 1.8; color: var(--dark-mid); margin-bottom: 20px; }
  .detail-content h3 { font-size: 1.5rem; color: var(--dark); margin: 35px 0 15px; font-weight: 600; }
  .detail-content ul { margin-left: 25px; margin-bottom: 25px; }
  .detail-content li { font-size: 1.05rem; line-height: 1.8; color: var(--dark-mid); margin-bottom: 8px; }
  .detail-content strong { color: var(--dark); }
  .cta-box { background: var(--cream); padding: 35px; border-radius: 10px; text-align: center; margin-top: 40px; }
  .cta-box p { font-size: 1.2rem; color: var(--dark); margin-bottom: 20px; }
  .back-link { margin-top: 30px; }
  .back-link a { display: inline-flex; align-items: center; gap: 6px; color: var(--primary); font-size: 1.05rem; text-decoration: none; font-weight: 500; transition: color 0.3s ease; }
  .back-link a:hover { color: var(--primary-dark, var(--dark)); }
  .back-link .arrow { font-size: 1.2rem; }
  @media (max-width: 968px) {
    .detail-grid { grid-template-columns: 1fr; gap: 30px; }
    .detail-image { position: static; max-width: 500px; margin: 0 auto; }
    .servicio-title { font-size: 1.8rem; }
  }
</style>
