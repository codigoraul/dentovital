---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset, resolveRoute } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout title="Hilos Tensores | Clínica Dentovital" description="Tratamiento con hilos tensores en Antofagasta. Efecto lifting inmediato sin cirugía, reafirma y tensa los tejidos del rostro." canonical="https://dentovital.cl/estetica-facial/hilos-tensores">
  <Header />

  <main style="margin-top: 90px;">
    <PageHero
      title="Hilos Tensores"
      description="Efecto lifting inmediato sin cirugía para reafirmar y tensar tu rostro"
      backgroundImage="images/bg-title/bg-estetica-facial.webp"
    />

    <section class="servicio-detail">
      <div class="container">
        <div class="detail-grid">
          <!-- Columna imagen (40%) -->
          <div class="detail-image">
            <img src={asset('images/estetica-facial/Hilos-tensores.webp')} alt="Hilos Tensores" />
          </div>

          <!-- Columna contenido (60%) -->
          <div class="detail-content">
            <h2 class="servicio-title">Hilos Tensores</h2>

            <p>
              Los hilos tensores son un tratamiento estético avanzado que permite
              <strong>reafirmar, tensar y reposicionar los tejidos del rostro y cuello</strong>,
              logrando un efecto lifting inmediato sin necesidad de cirugía.
            </p>
            <p>
              En Clínica Dentovital trabajamos con un enfoque <strong>médico-estético preciso</strong>,
              evaluando la estructura facial y el grado de flacidez para obtener resultados
              <strong>naturales, elegantes y armónicos</strong>.
            </p>

            <h3>¿Qué son los hilos tensores?</h3>
            <p>
              Son hilos biocompatibles (generalmente de PDO) que se insertan bajo la piel para generar dos efectos clave:
            </p>
            <ul>
              <li><strong>Efecto lifting inmediato</strong> (reposicionamiento de tejidos)</li>
              <li><strong>Bioestimulación de colágeno</strong> (mejora progresiva de la piel)</li>
            </ul>

            <h3>¿Qué zonas se pueden tratar?</h3>
            <ul>
              <li>Mejillas caídas</li>
              <li>Línea mandibular (papada y contorno facial)</li>
              <li>Surcos nasogenianos</li>
              <li>Elevación de cejas</li>
            </ul>

            <div class="cta-box">
              <p>¿Quieres un efecto lifting sin cirugía?</p>
              <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
            </div>

            <div class="back-link">
              <a href={resolveRoute(Astro, '/estetica-facial')}>
                <span class="arrow">&larr;</span> Volver a Estética Facial
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .servicio-detail {
    padding: 80px 0;
    background: #fff;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 50px;
    align-items: start;
  }

  .detail-image {
    position: sticky;
    top: 120px;
  }

  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .detail-content {
    padding-top: 0;
  }

  .servicio-title {
    font-size: 2.2rem;
    color: var(--dark);
    margin-bottom: 25px;
    font-weight: 700;
    line-height: 1.2;
  }

  .detail-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 20px;
  }

  .detail-content h3 {
    font-size: 1.5rem;
    color: var(--dark);
    margin: 35px 0 15px;
    font-weight: 600;
  }

  .detail-content ul {
    margin-left: 25px;
    margin-bottom: 25px;
  }

  .detail-content li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 8px;
  }

  .detail-content strong {
    color: var(--dark);
  }

  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 40px;
  }

  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }

  .back-link {
    margin-top: 30px;
  }

  .back-link a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-size: 1.05rem;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .back-link a:hover {
    color: var(--primary-dark, var(--dark));
  }

  .back-link .arrow {
    font-size: 1.2rem;
  }

  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .detail-image {
      position: static;
      max-width: 500px;
      margin: 0 auto;
    }

    .servicio-title {
      font-size: 1.8rem;
    }
  }
</style>
