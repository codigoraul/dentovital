---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout
  title="Periodoncia en Antofagasta | Tratamiento de Encías | Clínica Dentovital"
  description="Tratamiento especializado de encías y enfermedades periodontales en Antofagasta. Prevención y cuidado de tejidos de soporte dental. Agenda en Clínica Dentovital."
  canonical="https://dentistaantofagasta.cl/especialidad/periodoncia"
>
  <Header />
  
  <main style="margin-top: 90px;">
    <PageHero 
      title="Periodoncia"
      description="Tratamiento de encías y tejidos de soporte dental"
      backgroundImage="images/especialidades/periodoncia.webp"
    />
    
    <section class="especialidad-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-content">
            <div class="detail-text">
              <p>
                La periodoncia es la especialidad que se encarga de cuidar las encías y el soporte del diente (hueso y ligamentos).
              </p>
              <p>
                Se trata cuando hay problemas como sangrado, inflamación o movilidad dental, eliminando bacterias y sarro acumulado para detener la enfermedad.
              </p>
              <p>
                El objetivo es mantener tus dientes firmes y sanos, evitando su pérdida y mejorando la salud de tu boca.
              </p>
              
              <h3>Enfermedades Periodontales</h3>
              <ul>
                <li><strong>Gingivitis:</strong> Inflamación de encías, reversible con tratamiento</li>
                <li><strong>Periodontitis:</strong> Infección que daña tejidos y hueso de soporte</li>
                <li><strong>Periodontitis avanzada:</strong> Pérdida significativa de soporte dental</li>
              </ul>
              
              <h3>Síntomas de Alerta</h3>
              <ul>
                <li>Encías rojas, inflamadas o sensibles</li>
                <li>Sangrado al cepillar o usar hilo dental</li>
                <li>Mal aliento persistente</li>
                <li>Retracción de encías</li>
                <li>Dientes flojos o separados</li>
                <li>Cambios en la mordida</li>
                <li>Pus entre dientes y encías</li>
              </ul>
              
              <h3>Tratamientos Periodontales</h3>
              <ul>
                <li>Limpieza dental profesional</li>
                <li>Raspado y alisado radicular</li>
                <li>Cirugía periodontal</li>
                <li>Injertos de encía</li>
                <li>Regeneración ósea guiada</li>
                <li>Mantenimiento periodontal</li>
              </ul>
              
              <h3>Prevención</h3>
              <ul>
                <li>Cepillado correcto 3 veces al día</li>
                <li>Uso diario de hilo dental</li>
                <li>Enjuague bucal antimicrobiano</li>
                <li>Controles dentales regulares</li>
                <li>No fumar</li>
                <li>Dieta balanceada</li>
              </ul>
              
              <div class="cta-box">
                <p>Cuida la salud de tus encías</p>
                <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
              </div>
            </div>
          </div>
          
          <div class="detail-image">
            <img src={asset('images/especialidades/periodoncia.webp')} alt="Periodoncia" />
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .especialidad-detail {
    padding: 80px 0;
    background: #fff;
  }
  
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  
  .detail-content h1 {
    font-size: 3rem;
    color: var(--dark);
    margin-bottom: 30px;
  }
  
  .detail-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 25px;
  }
  
  .detail-text h3 {
    font-size: 1.8rem;
    color: var(--dark);
    margin: 40px 0 20px;
  }
  
  .detail-text ul,
  .detail-text ol {
    margin-left: 25px;
    margin-bottom: 30px;
  }
  
  .detail-text li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 12px;
  }
  
  .detail-text strong {
    color: var(--dark);
  }
  
  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 50px;
  }
  
  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }
  
  .detail-image {
    position: sticky;
    top: 120px;
  }
  
  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .detail-content h1 {
      font-size: 2.2rem;
    }
    
    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }
    
    .detail-image {
      position: static;
    }
  }
</style>
