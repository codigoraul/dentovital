---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout
  title="Endodoncia en Antofagasta | Tratamiento de Conducto | Clínica Dentovital"
  description="Tratamiento de endodoncia y conductos radiculares en Antofagasta con tecnología avanzada. Salva tu diente y elimina el dolor. Agenda en Clínica Dentovital."
  canonical="https://dentovital.cl/especialidad/endodoncia"
>
  <Header />
  
  <main style="margin-top: 90px;">
    <PageHero 
      title="Endodoncia"
      description="Tratamiento de conductos radiculares con tecnología avanzada"
      backgroundImage="images/especialidades/endodoncia.webp"
    />
    
    <section class="especialidad-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-content">
            <div class="detail-text">
              <p>
                La endodoncia, también conocida como tratamiento de conducto, es el procedimiento que 
                permite salvar dientes que han sido afectados por caries profundas, traumatismos o 
                infecciones en la pulpa dental.
              </p>
              <p>
                En Clínica Dentovital realizamos endodoncias con tecnología avanzada y microscopía 
                dental, lo que nos permite mayor precisión y mejores resultados en el tratamiento.
              </p>
              
              <h3>¿Cuándo se necesita una Endodoncia?</h3>
              <ul>
                <li>Dolor dental intenso y persistente</li>
                <li>Sensibilidad extrema al frío o calor</li>
                <li>Inflamación de encías alrededor del diente</li>
                <li>Oscurecimiento del diente</li>
                <li>Absceso o fístula dental</li>
                <li>Fractura dental con exposición pulpar</li>
              </ul>
              
              <h3>Proceso del Tratamiento</h3>
              <ol>
                <li><strong>Diagnóstico:</strong> Evaluación clínica y radiográfica</li>
                <li><strong>Anestesia local:</strong> Para un tratamiento sin dolor</li>
                <li><strong>Aislamiento:</strong> Colocación de dique de goma</li>
                <li><strong>Limpieza de conductos:</strong> Eliminación de tejido infectado</li>
                <li><strong>Desinfección:</strong> Irrigación con soluciones especiales</li>
                <li><strong>Obturación:</strong> Sellado hermético de los conductos</li>
                <li><strong>Restauración:</strong> Corona o reconstrucción final</li>
              </ol>
              
              <h3>Ventajas de la Endodoncia</h3>
              <ul>
                <li>Salva el diente natural</li>
                <li>Elimina el dolor e infección</li>
                <li>Procedimiento predecible y exitoso</li>
                <li>Evita la extracción dental</li>
                <li>Preserva la función masticatoria</li>
              </ul>
              
              <div class="cta-box">
                <p>¿Tienes dolor dental? Podemos ayudarte</p>
                <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
              </div>
            </div>
          </div>
          
          <div class="detail-image">
            <img src={asset('images/especialidades/endodoncia.webp')} alt="Endodoncia" />
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .especialidad-detail {
    padding: 80px 0;
    background: #fff;
  }
  
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  
  .detail-content h1 {
    font-size: 3rem;
    color: var(--dark);
    margin-bottom: 30px;
  }
  
  .detail-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 25px;
  }
  
  .detail-text h3 {
    font-size: 1.8rem;
    color: var(--dark);
    margin: 40px 0 20px;
  }
  
  .detail-text ul,
  .detail-text ol {
    margin-left: 25px;
    margin-bottom: 30px;
  }
  
  .detail-text li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 12px;
  }
  
  .detail-text strong {
    color: var(--dark);
  }
  
  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 50px;
  }
  
  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }
  
  .detail-image {
    position: sticky;
    top: 120px;
  }
  
  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .detail-content h1 {
      font-size: 2.2rem;
    }
    
    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }
    
    .detail-image {
      position: static;
    }
  }
</style>
