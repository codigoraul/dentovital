---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout
  title="Odontología General en Antofagasta | Dentista para toda la Familia | Clínica Dentovital"
  description="Atención odontológica integral para toda la familia en Antofagasta. Limpieza dental, caries, extracciones y más con enfoque preventivo en Clínica Dentovital."
  canonical="https://dentistaantofagasta.cl/especialidad/odontologia-general"
>
  <Header />
  
  <main style="margin-top: 90px;">
    <PageHero 
      title="Odontología General"
      description="Atención integral para toda la familia con enfoque preventivo"
      backgroundImage="images/bg-title/bg-especialidades.webp"
    />
    
    <section class="especialidad-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-content">
            <div class="detail-text">
              <p>
                La odontología general es la base de la salud bucal. Nos enfocamos en la prevención, 
                diagnóstico y tratamiento de las enfermedades más comunes de dientes y encías, 
                atendiendo a pacientes de todas las edades.
              </p>
              <p>
                Nuestro objetivo es mantener tu salud bucal en óptimas condiciones mediante 
                controles periódicos, tratamientos preventivos y procedimientos restauradores 
                de alta calidad.
              </p>
              
              <h3>Servicios de Odontología General</h3>
              <ul>
                <li><strong>Examen dental completo:</strong> Evaluación integral de dientes, encías y salud oral para detectar problemas a tiempo. 
</li>
                <li><strong>Limpieza dental profesional:</strong> Eliminación de sarro y placa bacteriana para prevenir caries y enfermedades gingivales. </li>
                <li><strong>Obturaciones (tapaduras):</strong> Restauración de dientes con caries o fracturas mediante materiales estéticos y resistentes. </li>
                <li><strong>Extracciones simples:</strong> Remoción de piezas dentales dañadas o sin posibilidad de recuperación. 
</li>
                <li><strong>Tratamiento de encías:</strong> Manejo de gingivitis y periodontitis para recuperar salud gingival. 
</li>
                <li><strong>Radiografías dentales:</strong> Imágenes diagnósticas para evaluar dientes, raíces, hueso y estructuras internas</li>
                <li><strong>Sellantes dentales:</strong> Barrera protectora aplicada en molares para prevenir caries</li>
                <li><strong>Fluoración:</strong> Aplicación de flúor para fortalecer el esmalte y reducir riesgo de caries</li>
              </ul>
              
              <h3>Importancia de los Controles Regulares</h3>
              <p>
                Las visitas periódicas al dentista (cada 6 meses) permiten detectar problemas 
                en etapas tempranas, cuando son más fáciles y económicos de tratar. La prevención 
                es la clave para mantener una sonrisa saludable.
              </p>
              
              <h3>Beneficios de la Odontología Preventiva</h3>
              <ul>
                <li>Prevención de caries y enfermedades de encías</li>
                <li>Detección temprana de problemas</li>
                <li>Ahorro en tratamientos futuros</li>
                <li>Mantenimiento de dientes naturales</li>
                <li>Mejora de la salud general</li>
                <li>Educación en higiene oral</li>
              </ul>
              
              <h3>Atención para Toda la Familia</h3>
              <p>
                Ofrecemos atención dental para niños, adolescentes, adultos y adultos mayores. 
                Cada etapa de la vida requiere cuidados específicos, y nuestro equipo está 
                capacitado para brindar el mejor tratamiento a cada miembro de tu familia.
              </p>
              
              <h3>Prevención</h3>
              <ul>
                <li>Cepillado correcto 3 veces al día</li>
                <li>Uso diario de hilo dental</li>
                <li>Controles dentales regulares</li>
                <li>No fumar</li>
                <li>Dieta balanceada</li>
              </ul>
              
              <div class="cta-box">
                <p>¿Cuándo fue tu último control dental?</p>
                <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Control</a>
              </div>
            </div>
          </div>
          
          <div class="detail-image">
            <img src={asset('images/especialidades/odontologia-general.webp')} alt="Odontología General" />
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .especialidad-detail {
    padding: 80px 0;
    background: #fff;
  }
  
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  
  .detail-content h1 {
    font-size: 3rem;
    color: var(--dark);
    margin-bottom: 30px;
  }
  
  .detail-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 25px;
  }
  
  .detail-text h3 {
    font-size: 1.8rem;
    color: var(--dark);
    margin: 40px 0 20px;
  }
  
  .detail-text ul,
  .detail-text ol {
    margin-left: 25px;
    margin-bottom: 30px;
  }
  
  .detail-text li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 12px;
  }
  
  .detail-text strong {
    color: var(--dark);
  }
  
  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 50px;
  }
  
  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }
  
  .detail-image {
    position: sticky;
    top: 120px;
  }
  
  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .detail-content h1 {
      font-size: 2.2rem;
    }
    
    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }
    
    .detail-image {
      position: static;
    }
  }
</style>
