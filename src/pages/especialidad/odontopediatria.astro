---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout
  title="Odontopediatría en Antofagasta | Dentista para Niños | Clínica Dentovital"
  description="Atención dental especializada para niños y adolescentes en Antofagasta. Cuidado preventivo y tratamientos en un ambiente amigable. Agenda en Clínica Dentovital."
  canonical="https://dentistaantofagasta.cl/especialidad/odontopediatria"
>
  <Header />
  
  <main style="margin-top: 90px;">
    <PageHero 
      title="Odontopediatría"
      description="Cuidado dental especializado para niños y adolescentes"
      backgroundImage="images/especialidades/odontopediatria.webp"
    />
    
    <section class="especialidad-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-content">
            <div class="detail-text">
              <p>
                Creamos una experiencia cercana y amigable, donde cada cita se transforma en una oportunidad para enseñar, prevenir y cuidar su sonrisa sin miedo.
              </p>
              
              <h3>Servicios de Odontopediatría</h3>
              <ul>
                <li>Control y prevención dental infantil</li>
                <li>Aplicación de flúor y sellantes</li>
                <li>Tratamiento de caries en dientes temporales</li>
                <li>Pulpotomías y pulpectomías</li>
                <li>Manejo de traumatismos dentales</li>
                <li>Educación en higiene oral</li>
                <li>Seguimiento del desarrollo dental</li>
              </ul>
              
              <h3>Primera Visita al Dentista</h3>
              <p>
                Recomendamos la primera visita dental cuando aparece el primer diente. Las visitas tempranas permiten:
              </p>
              <ul>
                <li>Detectar problemas a tiempo</li>
                <li>Establecer una relación positiva con el dentista</li>
                <li>Educar a los padres sobre cuidado dental infantil</li>
                <li>Prevenir caries y otros problemas</li>
              </ul>
              
              <h3>Prevención de Caries Infantil</h3>
              <ul>
                <li>Cepillado supervisado 3 veces al día</li>
                <li>Uso de pasta dental con flúor apropiada</li>
                <li>Alimentación saludable baja en azúcares</li>
                <li>Sellantes dentales en molares permanentes</li>
                <li>Controles dentales cada 6 meses</li>
              </ul>
              
              <div class="cta-box">
                <p>Cuida la sonrisa de tus hijos desde pequeños</p>
                <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Control</a>
              </div>
            </div>
          </div>
          
          <div class="detail-image">
            <img src={asset('images/especialidades/odontopediatria.webp')} alt="Odontopediatría" />
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .especialidad-detail {
    padding: 80px 0;
    background: #fff;
  }
  
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  
  .detail-content h1 {
    font-size: 3rem;
    color: var(--dark);
    margin-bottom: 30px;
  }
  
  .detail-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 25px;
  }
  
  .detail-text h3 {
    font-size: 1.8rem;
    color: var(--dark);
    margin: 40px 0 20px;
  }
  
  .detail-text ul,
  .detail-text ol {
    margin-left: 25px;
    margin-bottom: 30px;
  }
  
  .detail-text li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 12px;
  }
  
  .detail-text strong {
    color: var(--dark);
  }
  
  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 50px;
  }
  
  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }
  
  .detail-image {
    position: sticky;
    top: 120px;
  }
  
  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .detail-content h1 {
      font-size: 2.2rem;
    }
    
    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }
    
    .detail-image {
      position: static;
    }
  }
</style>
