---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import PageHero from '../../components/PageHero.astro';
import { resolveAsset } from '../../lib/assets';

const asset = (path: string) => resolveAsset(Astro, path);
---

<MainLayout
  title="Estética Facial en Antofagasta | Botox, Ácido Hialurónico | Clínica Dentovital"
  description="Tratamientos de estética facial en Antofagasta: botox, ácido hialurónico, armonización facial, hilos tensores y más. Resultados naturales en Clínica Dentovital."
  canonical="https://dentovital.cl/especialidad/estetica-facial"
>
  <Header />
  
  <main style="margin-top: 90px;">
    <PageHero 
      title="Estética Facial"
      description="Armonización y rejuvenecimiento facial con técnicas no invasivas"
      backgroundImage="images/especialidades/estetica-facial.webp"
    />
    
    <section class="especialidad-detail">
      <div class="container">
        <div class="detail-grid">
          <div class="detail-content">
            <div class="detail-text">
              <p>
                La estética facial complementa la odontología estética para lograr una armonización 
                completa del rostro. Utilizamos técnicas mínimamente invasivas y productos de la 
                más alta calidad para resultados naturales y seguros.
              </p>
              <p>
                Nuestros tratamientos de estética facial están diseñados para rejuvenecer, armonizar 
                y realzar los rasgos faciales, siempre respetando la naturalidad de cada paciente.
              </p>
              
              <h3>Tratamientos Disponibles</h3>
              <ul>
                <li><strong>Armonización facial:</strong> Procedimientos estéticos mínimamente invasivos para equilibrar proporciones y realzar rasgos faciales</li>
                <li><strong>Botox / Dysport:</strong> Reducción de arrugas de expresión</li>
                <li><strong>Ácido hialurónico:</strong> Relleno y voluminización</li>
                <li><strong>Bioestimuladores de colágeno:</strong> Rejuvenecimiento natural</li>
                <li><strong>Hilos tensores:</strong> Lifting sin cirugía</li>
                <li><strong>Hilos revitalizantes:</strong> Estimulación de colágeno</li>
                <li><strong>Mesoterapia facial:</strong> Hidratación y luminosidad</li>
                <li><strong>HIFU:</strong> Ultrasonido focalizado de alta intensidad</li>
                <li><strong>Endolaser:</strong> Tratamiento de papada</li>
                <li><strong>Bichectomía:</strong> Afinamiento facial</li>
              </ul>
              
              <h3>Beneficios de los Tratamientos</h3>
              <ul>
                <li>Resultados naturales y armónicos</li>
                <li>Procedimientos mínimamente invasivos</li>
                <li>Recuperación rápida</li>
                <li>Sin cirugía ni hospitalización</li>
                <li>Mejora visible desde la primera sesión</li>
                <li>Tratamientos personalizados</li>
              </ul>
              
              <h3>¿Para quién están indicados?</h3>
              <p>
                Los tratamientos de estética facial son ideales para personas que desean mejorar 
                su apariencia de forma natural, prevenir el envejecimiento prematuro, o corregir 
                asimetrías faciales sin someterse a cirugías invasivas.
              </p>
              
              <h3>Áreas de Tratamiento</h3>
              <ul>
                <li>Frente y entrecejo</li>
                <li>Contorno de ojos (patas de gallo)</li>
                <li>Pómulos y mejillas</li>
                <li>Surcos nasogenianos</li>
                <li>Labios y contorno labial</li>
                <li>Mentón y mandíbula</li>
                <li>Cuello y papada</li>
              </ul>
              
              <div class="cta-box">
                <p>¿Quieres armonizar tu rostro?</p>
                <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">Agendar Evaluación</a>
              </div>
            </div>
          </div>
          
          <div class="detail-image">
            <img src={asset('images/especialidades/estetica-facial.webp')} alt="Estética Facial" />
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .especialidad-detail {
    padding: 80px 0;
    background: #fff;
  }
  
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  
  .detail-content h1 {
    font-size: 3rem;
    color: var(--dark);
    margin-bottom: 30px;
  }
  
  .detail-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 25px;
  }
  
  .detail-text h3 {
    font-size: 1.8rem;
    color: var(--dark);
    margin: 40px 0 20px;
  }
  
  .detail-text ul,
  .detail-text ol {
    margin-left: 25px;
    margin-bottom: 30px;
  }
  
  .detail-text li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-mid);
    margin-bottom: 12px;
  }
  
  .detail-text strong {
    color: var(--dark);
  }
  
  .cta-box {
    background: var(--cream);
    padding: 35px;
    border-radius: 10px;
    text-align: center;
    margin-top: 50px;
  }
  
  .cta-box p {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 20px;
  }
  
  .detail-image {
    position: sticky;
    top: 120px;
  }
  
  .detail-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  @media (max-width: 968px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .detail-content h1 {
      font-size: 2.2rem;
    }
    
    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }
    
    .detail-image {
      position: static;
    }
  }
</style>
