---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppBtn from '../components/WhatsAppBtn.astro';
import PageHero from '../components/PageHero.astro';

const procedimientos = [
  "Armonización facial",
  "Botox / Dysport",
  "Ácido hialurónico",
  "Bioestimuladores de colágeno",
  "Hilos tensores",
  "Hilos revitalizantes",
  "Exosomas + ADN salmón",
  "Mesoterapia: Pink Glow, Orchid Glow, Amber Glow, NCTF",
  "HIFU",
  "Endolaser",
  "Bichectomía"
];
---

<MainLayout title="Estética Facial | Clínica Dentovital" description="Tratamientos de estética facial en Antofagasta">
  <Header />
  
  <main style="margin-top: 90px;">
    <PageHero 
      title="Estética Facial"
      description="Tratamientos de rejuvenecimiento y armonización facial"
      backgroundImage="images/bg-title/bg-estetica-facial.webp"
    />
    
    <section class="section">
      <div class="container">
        <div class="intro-text">
          <p>
            En Clínica Dentovital combinamos la odontología estética con tratamientos 
            faciales de última generación para ofrecerte una armonización completa de tu rostro.
          </p>
          <p>
            Nuestros procedimientos son mínimamente invasivos, seguros y con resultados naturales.
          </p>
        </div>
        
        <div class="procedimientos-grid">
          {procedimientos.map(proc => (
            <div class="procedimiento-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{proc}</span>
            </div>
          ))}
        </div>
        
        <div class="cta-section">
          <a href="https://ff.healthatom.io/ZCokP6" target="_blank" class="btn btn-primary">
            Agendar Evaluación
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppBtn />
</MainLayout>

<style>
  .hero-page {
    background: var(--dark);
    color: var(--white);
    padding: 100px 0 80px;
    text-align: center;
  }
  
  .hero-page h1 {
    font-size: 3rem;
    margin-bottom: 15px;
  }
  
  .hero-page p {
    font-size: 1.2rem;
    color: var(--primary-light);
  }
  
  .intro-text {
    max-width: 800px;
    margin: 0 auto 60px;
    text-align: center;
  }
  
  .intro-text p {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 20px;
    color: var(--dark-mid);
  }
  
  .procedimientos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-bottom: 60px;
  }
  
  .procedimiento-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 20px 25px;
    background: #fff;
    border-left: 3px solid var(--primary);
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
  }
  
  .procedimiento-item:hover {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transform: translateX(5px);
  }
  
  .procedimiento-item svg {
    color: var(--primary);
    flex-shrink: 0;
  }
  
  .procedimiento-item span {
    font-size: 1rem;
    font-weight: 500;
    color: var(--dark);
  }
  
  .cta-section {
    text-align: center;
  }
  
  @media (max-width: 768px) {
    .hero-page h1 {
      font-size: 2.2rem;
    }
    
    .procedimientos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
